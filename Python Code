import nltk
from nltk.tokenize import sent_tokenize

#Analysing the company annual reports
#Importing the PDF report
reader = PdfReader(r"...\Financial Reports Sentiment\UMEME Annual Reports\Umeme-Annual Report-2024.pdf")

#Converting PDF report to text
full_text = ""
for page in reader.pages:
    page_text = page.extract_text()
    if page_text:
        full_text += page_text + "\n"


sentiment_totals = {}
sentiment_counts = {}
LabelWeight = {
    "Positive":1, "Negative":-1, "Neutral":0
}
compoundedTotal = 0
TotalWeight = 0
Sentences = []

#Splitting text into sentences/tokens using regular expressions and full stop delimiter.
tokens = re.split(r'(?<=[^0-9])\.(?=\s|$)', full_text)
#tokens = sent_tokenize(full_text)

# Write results to CSV
output_path = "sentiment_results.csv"

with open(output_path, mode="w", encoding="utf-8", newline="") as file:
    writer = csv.writer(file, quoting=csv.QUOTE_ALL)
    writer.writerow(["Sentiment Label", "Confidence Score", "Token Text"])

    for i, token in enumerate(tokens):
        token = token.strip()
        if token:  # Skip empty strings
            try:
                result = nlp(token[:])[0]
                label = result['label'].capitalize()
                score = result['score']
                Sentences.append(
                    {"Sentiment": label,
                     "full_text": token
                    }
                )
                weight = LabelWeight.get(label, 0)
                #print(f"Token {i+1}: [{label}] ({score:.2f}) - {token}")
                sentiment_totals[label] = sentiment_totals.get(label, 0) + score
                sentiment_counts[label] = sentiment_counts.get(label, 0) + 1
                compoundedTotal += weight*score
                TotalWeight += score
                writer.writerow([label, f"{score:.2f}", token])
            except Exception as e:
                #print()
                print(f"Error processing token {i+1}: {e}")


CompoundScore = compoundedTotal / TotalWeight if TotalWeight > 0 else 0

print(sentiment_counts)

print("Sentiment Summary:")
for label in sentiment_totals:
    average = sentiment_totals[label] / sentiment_counts[label]
    print(f"{label.capitalize()}: {average:.2f}")


print(f"Compound Score: {CompoundScore:.2f}")

