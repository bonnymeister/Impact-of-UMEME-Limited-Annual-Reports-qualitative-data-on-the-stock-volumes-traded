#NRC Lexicon
from collections import Counter

# Load NRC lexicon
nrc = {}
with open(r"...\Financial Reports Sentiment\NRC-Emotion-Lexicon\NRC-Emotion-Lexicon\NRC-Emotion-Lexicon-Wordlevel-v0.92.txt", "r", encoding="utf-8") as f:
    for line in f:
        word, emotion, association = line.strip().split('\t')
        if association == '1':
            nrc.setdefault(word, []).append(emotion)

# Function to get NRC sentiment label
def get_nrc_sentiment(text):
    words = str(text).lower().split()
    emotions = []
    for word in words:
        if word in nrc:
            emotions.extend(nrc[word])
    counts = Counter(emotions)

    # Simplified polarity logic
    if counts['Positive'] > counts['Negative']:
        return 'Positive'
    elif counts['Negative'] > counts['Positive']:
        return 'Negative'
    else:
        return 'Neutral'

# Apply NRC
df['nrc_prediction'] = df['text'].apply(get_nrc_sentiment)

# Evaluate
accuracy = accuracy_score(df['label'], df['nrc_prediction'])
print(f"NRC Accuracy: {accuracy:.2%}")
print("\nClassification Report:")
print(classification_report(df['label'], df['nrc_prediction'], digits=2))


