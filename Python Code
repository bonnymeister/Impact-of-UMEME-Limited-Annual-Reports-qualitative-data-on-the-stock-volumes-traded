#VADER
import pandas as pd
from vaderSentiment.vaderSentiment import SentimentIntensityAnalyzer
from sklearn.metrics import classification_report, accuracy_score

#Load data
df = pd.read_csv(r"...\Financial Reports Sentiment\Regular Expressions ProsusAI-FinBERT\UMEMESentimentEvaluations.csv", header=None)
df.columns = ['text', 'label']


#Initialise VADER
analyser = SentimentIntensityAnalyzer()

# Convert compound score to sentiment label
def get_vader_label(text):
    score = analyser.polarity_scores(text)['compound']
    if score >= 0.05:
        return 'Positive'
    elif score <= -0.05:
        return 'Negative'
    else:
        return 'Neutral'

# Apply VADER to each text
df['vader_prediction'] = df['text'].apply(get_vader_label)

# Accuracy
accuracy = accuracy_score(df['label'], df['vader_prediction'])
print(f"Accuracy: {accuracy:.2%}")

# Precision, Recall, F1
print("\nClassification Report:")
print(classification_report(df['label'], df['vader_prediction'], digits=2))

