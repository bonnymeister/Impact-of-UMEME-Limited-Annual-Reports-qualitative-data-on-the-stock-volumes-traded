# Load BERT sentiment pipeline
classifier = pipeline("sentiment-analysis", model="nlptown/bert-base-multilingual-uncased-sentiment")

# Load labeled data manually
BertData = r"...\Financial Reports Sentiment\Regular Expressions ProsusAI-FinBERT\UMEMESentimentEvaluations.csv"

Sentences = []
Sentiment = []

with open(BertData, mode="r", encoding="utf-8", errors="replace", newline="") as csvfile:
    reader = csv.reader(csvfile, delimiter=",")
    for row in reader:
        if len(row) == 2:
            sentence, label = row
            Sentences.append(sentence.strip())
            Sentiment.append(label.strip().lower())

# Map BERT output to sentiment label
def get_bert_label(text):
    result = classifier(text[:512])[0]['label']
    if '1' in result or '2' in result:
        return 'negative'
    elif '3' in result:
        return 'neutral'
    else:
        return 'positive'

# Apply BERT to each sentence
Predictions = []
for i, sentence in enumerate(Sentences):
    try:
        prediction = get_bert_label(sentence)
        Predictions.append(prediction)
    except Exception as e:
        print(f"Error processing sentence {i}: {e}")


# Evaluate
accuracy = accuracy_score(Sentiment, Predictions)
print(f"BERT Accuracy: {accuracy:.2%}")
print("\nClassification Report:")
print(classification_report(Sentiment, Predictions, digits=2))


