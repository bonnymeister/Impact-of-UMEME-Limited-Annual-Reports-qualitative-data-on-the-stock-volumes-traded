from textblob import TextBlob

# Function to convert TextBlob polarity to sentiment label
def get_textblob_label(text):
    polarity = TextBlob(str(text)).sentiment.polarity
    if polarity > 0.05:
        return 'Positive'
    elif polarity < -0.05:
        return 'Negative'
    else:
        return 'Neutral'

# Apply TextBlob
df['textblob_prediction'] = df['text'].apply(get_textblob_label)

# Accuracy
accuracy = accuracy_score(df['label'], df['textblob_prediction'])
print(f"TextBlob Accuracy: {accuracy:.2%}")

# Precision, Recall, F1
print("\nClassification Report:")
print(classification_report(df['label'], df['textblob_prediction'], digits=2))

